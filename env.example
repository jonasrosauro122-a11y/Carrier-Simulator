# Vercel / local build variables for LAVA CarrierOps
# Use Supabase Project URL + publishable key or legacy anon public key only.
# NEVER use service_role or sb_secret in this frontend app.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_PUBLIC_KEY_HERE
SUPABASE_BUCKET=carrier-documents
LAVA_TRAINER_CODE=TRAINER2026
